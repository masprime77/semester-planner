{
  "name": "@lectio/desktop",
  "version": "1.8.8",
  "description": "Lectio desktop app (Electron) for planning a university semester",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "sync-core": "node scripts/sync-core.js",
    "bundle-deps": "node scripts/bundle-deps.js",
    "clean-deps": "node scripts/clean-deps.js",
    "prestart": "npm run sync-core && npm run clean-deps",
    "start": "electron .",
    "predev": "npm run sync-core && npm run clean-deps",
    "dev": "electron . --dev-tools",
    "prebuild:mac": "npm run sync-core && npm run bundle-deps",
    "build:mac": "electron-builder --mac",
    "prebuild:win": "npm run sync-core && npm run bundle-deps",
    "build:win": "electron-builder --win",
    "icon": "bash assets/build-icns.sh",
    "icon:win": "node assets/build-ico.js",
    "icons": "npm run icon && npm run icon:win"
  },
  "dependencies": {
    "@lectio/core": "1.8.8",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.masprime77.lectio",
    "productName": "Lectio",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Lectio",
      "icon": "assets/icon.icns",
      "background": "assets/dmg-background.png",
      "artifactName": "Lectio-${arch}.${ext}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 185,
          "type": "file"
        },
        {
          "x": 390,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "Lectio-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "afterPack": "build/afterPack.js",
    "afterSign": "build/afterSign.js",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "app.js",
      "style.css",
      "planner-core.js",
      "semesters/",
      "assets/icon.png"
    ],
    "extraResources": [
      {
        "from": "semesters/",
        "to": "semesters/"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "masprime77",
      "repo": "lectio"
    }
  }
}
