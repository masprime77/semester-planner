{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@lectio/core": [
        "./types/lectio-core.d.ts"
      ],
      "@lectio/core/planner-core": [
        "./types/lectio-core.d.ts"
      ],
      "@lectio/core/storage/migrate": [
        "./types/lectio-core.d.ts"
      ],
      "@lectio/core/storage/contract": [
        "./types/lectio-core.d.ts"
      ],
      "@lectio/core/integrations/lectio-file": [
        "./types/lectio-core.d.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
